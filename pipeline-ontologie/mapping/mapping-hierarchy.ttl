@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix iadas: <http://ia-das.org/onto#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@base <http://ns.inria.fr/iadas/ACAD-vocab/>.


<#CategoryConceptSheme> a rr:TriplesMap ;
rml:logicalSource [
    rml:source "data-csv-converted/Class-Hierarchy-V1-cleaned.csv" ;
    rml:referenceFormulation ql:CSV
] ;
     
rr:subjectMap [
    rr:constant <http://ns.inria.fr/iadas/ACAD-vocab/Variable> ;
    rr:class skos:ConceptScheme
] ;
rr:predicateObjectMap [
    rr:predicate dcterms:title ;
    rr:objectMap [  rr:constant "IA-DAS - Thésaurus des Variables";
    rr:language "fr" ;
  ]];

rr:predicateObjectMap [
    rr:predicate dcterms:title ;
     rr:objectMap [rr:constant "IA-DAS - Variables thesaurus";
    rr:language "en" ;
  ]];


rr:predicateObjectMap [
    rr:predicate dcterms:description ;
     rr:objectMap [ rr:constant "Thésaurus pour décrire les variables ACAD citées dans les articles";
    rr:language "fr" ;
  ]];


rr:predicateObjectMap [
    rr:predicate dcterms:description ;
     rr:objectMap [ rr:constant "Tesaurus descriping ACAD variables cited on scientific papers";
    rr:language "en" ;
  ]];


rr:predicateObjectMap [
    rr:predicate dcterms:creator ;
     rr:objectMap [ rr:constant "Équipe de recherche IA-DAS";
    rr:language "en" ;
  ]];

rr:predicateObjectMap [
    rr:predicate dcterms:created ;
     rr:objectMap [ rr:constant "2025-11-25";
    rr:language "en" ;
  ]
  ];


rr:predicateObjectMap [
    rr:predicate dcterms:version ;
     rr:objectMap [ rr:constant "1.0";
    rr:language "en" ;
  ]
  ];
   .


<#VariableClass> a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "data-csv-converted/Class-Hierarchy-V1-cleaned.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    
    rr:subjectMap [
        rr:template "http://ns.inria.fr/iadas/ACAD-vocab/{CLASS}" ;
        rr:class skos:Concept
    ] ;

        
     # Associates each concept with its concept scheme
 rr:predicateObjectMap [
     rr:predicate skos:inScheme ;
     rr:objectMap [
         rr:constant <http://ns.inria.fr/iadas/ACAD-vocab/Variable> ;
 ] ;
 ] ;

    rr:predicateObjectMap [
        rr:predicate skos:narrower ;
        rr:objectMap [ rr:template "http://ns.inria.fr/iadas/ACAD-vocab/{sub-class 1}" ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ rml:reference "CLASS" ]
    ]
     .


<#VariableSubClass1> a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "data-csv-converted/Class-Hierarchy-V1-cleaned.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    
    rr:subjectMap [
        rr:template "http://ns.inria.fr/iadas/ACAD-vocab/{sub-class 1}" ;
        rr:class skos:Concept
    ] ;
    rr:predicateObjectMap [
    rr:predicate skos:inScheme ;
    rr:objectMap [
        rr:constant <http://ns.inria.fr/iadas/ACAD-vocab/Variable> ;
] ;
] ;

    rr:predicateObjectMap [
        rr:predicate skos:broader ;
        rr:objectMap [ rr:template "http://ns.inria.fr/iadas/ACAD-vocab/{CLASS}" ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ rml:reference "sub-class 1" ]
    ] ;
    
    # rr:predicateObjectMap [
        # rr:predicate rdfs:comment ;
        # rr:objectMap [ rml:reference "Définition" ]
    # ] ;
    # 
    rr:predicateObjectMap [
        rr:predicate skos:altLabel ;
        rr:objectMap [ rml:reference "Synonym" ]
    ] ;
    # 
    # rr:predicateObjectMap [
        # rr:predicate iadas:measurementTool ;
        # rr:objectMap [ rml:reference "Outils" ]
    # ] 
           
   rr:predicateObjectMap [
       rr:predicate skos:narrower ;
       rr:objectMap [ rr:template "http://ns.inria.fr/iadas/ACAD-vocab/{sub-class 2}" ]
   ] ;

    .


<#VariableSubClass2> a rr:TriplesMap ;
