<#AgeStatsMap> a rr:TriplesMap ;
    rml:logicalSource <#LogicalSource> ;
    rr:subjectMap [ 
        rr:template "http://ns.inria.fr/iadas/data/AgeStats_{Analysis_ID}" ; 
        rr:class iadas:AgeStatistics 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasDescription ; 
        rr:objectMap [ rml:reference "Age" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasMeanValue ; 
        rr:objectMap [ rml:reference "AgeForAnalysis_Mean" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasSdValue ; 
        rr:objectMap [ rml:reference "SDAnalysis" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasMinValue ; 
        rr:objectMap [ rml:reference "MinAge" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasMaxValue ; 
        rr:objectMap [ rml:reference "MaxAge" ] 
    ] .


<#BmiStatsMap> a rr:TriplesMap ;
    rml:logicalSource <#LogicalSource> ;
    rr:subjectMap [ 
        rr:template "http://ns.inria.fr/iadas/data/BmiStats_{Analysis_ID}" ; 
        rr:class iadas:BMIStatistics 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasDescription ; 
        rr:objectMap [ rml:reference "BMI" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasmeanValue ; 
        rr:objectMap [ rml:reference "BMI_Mean" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasSdValue ; 
        rr:objectMap [ rml:reference "BMI_SD" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasMinValue ; 
        rr:objectMap [ rml:reference "BMI_Min" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasMaxValue ; 
        rr:objectMap [ rml:reference "BMI_Max" ] 
    ] .



<#ExFreqStatsMap> a rr:TriplesMap ;
    rml:logicalSource <#LogicalSource> ;
    rr:subjectMap [ 
        rr:template "http://ns.inria.fr/iadas/data/ExFreqStats_{Analysis_ID}" ; 
        rr:class iadas:ExerciseFrequencyStatistics 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasDescription ; 
        rr:objectMap [ rml:reference "Exercise_frequency" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasMeanValue ; 
        rr:objectMap [ rml:reference "Freq_Mean" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasSdValue ; 
        rr:objectMap [ rml:reference "Freq_SD" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasMinValue ; 
        rr:objectMap [ rml:reference "Freq_Min" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasMaxValue ; 
        rr:objectMap [ rml:reference "Freq_Max" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasStatUnit ; 
        rr:objectMap [ rml:reference "Freq_Unit" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasStatBase ; 
        rr:objectMap [ rml:reference "Freq_Base" ] 
    ] .



<#ExpStatsMap> a rr:TriplesMap ;
    rml:logicalSource <#LogicalSource> ;
    rr:subjectMap [ 
        rr:template "http://ns.inria.fr/iadas/data/ExpStats_{Analysis_ID}" ; 
        rr:class iadas:YearsOfExperienceStatistics 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasDescription ; 
        rr:objectMap [ rml:reference "Years_of_experience" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasmeanValue ; 
        rr:objectMap [ rml:reference "Exp_Mean" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hassdValue ; 
        rr:objectMap [ rml:reference "Exp_SD" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasminValue; 
        rr:objectMap [ rml:reference "Exp_Min" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasmaxValue ; 
        rr:objectMap [ rml:reference "Exp_Max" ] 
    ] ;
    rr:predicateObjectMap [ 
        rr:predicate iadas:hasStatUnit ; 
        rr:objectMap [ rml:reference "Exp_Unit" ] 
    ] .
