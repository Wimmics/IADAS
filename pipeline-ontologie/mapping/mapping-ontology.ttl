<#AgeStatsMap> a rr:TriplesMap ;
    rml:logicalSource <#LogicalSource> ;
    rr:subjectMap [
        rr:template "http://ns.inria.fr/iadas/data/AgeStats_{Analysis_ID}" ;
        rr:class iadas:AgeStatistics
    ] ;
    rr:predicateObjectMap [
        rr:predicate iadas:hasMeanValue ;
        rr:objectMap [ rml:reference "Mean_Age" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate iadas:hasRange ;
        rr:objectMap [ rml:reference "Range_Age" ]
    ] .


<#BmiStatsMap> a rr:TriplesMap ;
    rml:logicalSource <#LogicalSource> ;
    rr:subjectMap [
        rr:template "http://ns.inria.fr/iadas/data/BmiStats_{Analysis_ID}" ;
        rr:class iadas:BMIStatistics
    ] ;
    rr:predicateObjectMap [
        rr:predicate iadas:hasMeanValue ;
        rr:objectMap [ rml:reference "Mean_BMI" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate iadas:hasRange ;
        rr:objectMap [ rml:reference "Range_BMI" ]
    ] .



<#ExFreqStatsMap> a rr:TriplesMap ;
    rml:logicalSource <#LogicalSource> ;
    rr:subjectMap [
        rr:template "http://ns.inria.fr/iadas/data/ExFreqStats_{Analysis_ID}" ;
        rr:class iadas:ExerciseFrequencyStatistics
    ] ;
    rr:predicateObjectMap [
        rr:predicate iadas:hasMeanValue ;
        rr:objectMap [ rml:reference "Mean_Exercise frequency" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate iadas:hasRange ;
        rr:objectMap [ rml:reference "Range_Exercise frequency" ]
    ] .



<#ExpStatsMap> a rr:TriplesMap ;
    rml:logicalSource <#LogicalSource> ;
    rr:subjectMap [
        rr:template "http://ns.inria.fr/iadas/data/ExpStats_{Analysis_ID}" ;
        rr:class iadas:YearsOfExperienceStatistics
    ] ;
    rr:predicateObjectMap [
        rr:predicate iadas:hasMeanValue ;
        rr:objectMap [ rml:reference "Mean_Years of experience" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate iadas:hasRange ;
        rr:objectMap [ rml:reference "Range_Years of experience" ]
    ] .
